{
  "name": "quasar-hud",
  "version": "0.1.0",
  "description": "Persistent terminal HUD for AI coding CLIs — Copilot, Claude, and Codex",
  "main": "dist/index.js",
  "bin": {
    "qhud": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --transpile-only src/index.tsx",
    "start": "node dist/index.js",
    "launch:copilot": "ts-node --transpile-only src/index.tsx -- --cli=copilot",
    "launch:claude": "ts-node --transpile-only src/index.tsx -- --cli=claude",
    "launch:codex": "ts-node --transpile-only src/index.tsx -- --cli=codex",
    "setup": "ts-node --transpile-only src/setup.ts"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "ink": "^3.2.0",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
